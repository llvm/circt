@LIT_SITE_CFG_IN_HEADER@

config.llvm_tools_dir = lit_config.substitute("@LLVM_TOOLS_DIR@")
config.circt_tools_dir = lit_config.substitute("@CIRCT_TOOLS_DIR@")
config.circt_standalone_obj_root = "@CIRCT_STANDALONE_BINARY_DIR@"
config.circt_standalone_tools_dir = "@LLVM_RUNTIME_OUTPUT_INTDIR@"
config.circt_standalone_libs_dir = "@LLVM_LIBRARY_OUTPUT_INTDIR@"
config.circt_standalone_has_plugin = @CIRCT_STANDALONE_HAS_PLUGIN@
config.llvm_shlib_ext = "@SHLIBEXT@"

import lit.llvm
lit.llvm.initialize(lit_config, config)

lit_config.load_config(config, "@CIRCT_STANDALONE_SOURCE_DIR@/test/lit.cfg.py")
